  {
       "name": "weathersite",
       "build": {
         "context": ".",
         "buildImage": "node:20-alpine",
         "buildCommand": "npm ci && npm run build",
         "buildOutput": "/src",
         "runImage": "node:20-alpine",
         "startCommand": "npm run start"
       },
       "deploy": {
         "port": 3000,
         "cpu": 100,
         "memoryMb": 512,
         "healthCheck": "/"
       }
     }

